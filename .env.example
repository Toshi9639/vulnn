# ──────────────────────────────────────────────────────────────
# VulnCenter — Environment Variables (.env.example)
# Copy this to .env and fill in your values
# Coolify will inject these at runtime
# ──────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://vulncenter:CHANGE_ME_PASSWORD@postgres:5432/vulncenter"

# ─── Redis / Queue ──────────────────────────────────────
REDIS_URL="redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379"
REDIS_PASSWORD="CHANGE_ME_REDIS_PASSWORD"

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET="CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"
JWT_EXPIRY="24h"

# ─── API Configuration ─────────────────────────────────
API_PORT=8000
API_HOST="0.0.0.0"
CORS_ORIGIN="https://app.vulncenter.example.com"
RATE_LIMIT_MAX=100
LOG_LEVEL="info"

# ─── Worker Configuration ─────────────────────────────
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT_MS=1800000
NUCLEI_TEMPLATES_PATH="/opt/nuclei-templates"
ALLOW_PRIVATE_IPS=false

# ─── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL="https://api.vulncenter.example.com"
NEXT_PUBLIC_APP_URL="https://app.vulncenter.example.com"
API_INTERNAL_URL="http://api:8000"

# ─── Postgres (Docker Compose only) ────────────────────
POSTGRES_USER="vulncenter"
POSTGRES_PASSWORD="CHANGE_ME_PASSWORD"
POSTGRES_DB="vulncenter"