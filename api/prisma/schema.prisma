// Minimal Prisma schema for API build
// The full schema is in db/schema.prisma - this is just for client generation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Placeholder models - just enough to generate the client
// Actual models are in db/schema.prisma
model User {
  id    String @id
  email String
}
